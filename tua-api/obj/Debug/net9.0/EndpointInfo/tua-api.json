{
  "openapi": "3.0.1",
  "info": {
    "title": "TUA Route API",
    "version": "v1"
  },
  "paths": {
    "/api/route/calculate": {
      "post": {
        "tags": [
          "Route"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RouteRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RouteRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RouteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CostWeights": {
        "type": "object",
        "properties": {
          "slopeWeight": {
            "type": "number",
            "format": "float"
          },
          "craterRiskWeight": {
            "type": "number",
            "format": "float"
          },
          "elevationWeight": {
            "type": "number",
            "format": "float"
          }
        },
        "additionalProperties": false
      },
      "GridNode": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "format": "int32"
          },
          "z": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "RoutePoint": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "format": "int32"
          },
          "z": {
            "type": "integer",
            "format": "int32"
          },
          "y": {
            "type": "number",
            "format": "float"
          },
          "localCost": {
            "type": "number",
            "format": "float"
          }
        },
        "additionalProperties": false
      },
      "RouteRequest": {
        "type": "object",
        "properties": {
          "startNode": {
            "$ref": "#/components/schemas/GridNode"
          },
          "endNode": {
            "$ref": "#/components/schemas/GridNode"
          },
          "gridSize": {
            "type": "integer",
            "format": "int32"
          },
          "heightMap": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "float"
            },
            "nullable": true
          },
          "craterMap": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "float"
            },
            "nullable": true
          },
          "costWeights": {
            "$ref": "#/components/schemas/CostWeights"
          }
        },
        "additionalProperties": false
      },
      "RouteResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "path": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoutePoint"
            },
            "nullable": true
          },
          "totalCost": {
            "type": "number",
            "format": "float"
          },
          "stepCount": {
            "type": "integer",
            "format": "int32"
          },
          "elapsedMs": {
            "type": "integer",
            "format": "int64"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}